# ── AlgoDesk Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your keys.

# ── Groq API (Free — llama-3.3-70b-versatile) ───────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Review Agents (The Smart Frontier Models)
# ── THE ARBITER (Highest Intelligence) ──
# Pulls from the openai/gpt-oss-120b bucket (8K TPM limit)
MODEL_ARBITER=groq/openai/gpt-oss-120b

# ── THE REVIEWERS (High Intelligence) ──
# Pulls from the llama 70B bucket (12K TPM limit)
MODEL_COMPLIANCE=groq/llama-3.3-70b-versatile
MODEL_STRESS_TEST=groq/llama-3.3-70b-versatile

# ── THE STRATEGISTS (Fast & Cheap) ──
# Pulls from the llama 8B bucket (6K TPM limit)
MODEL_MOMENTUM=groq/llama-3.1-8b-instant
MODEL_MEAN_REVERSION=groq/llama-3.1-8b-instant
MODEL_SENTIMENT=groq/llama-3.1-8b-instant

# Fallback
GROQ_MODEL=groq/llama-3.3-70b-versatile

# ── Band Platform (Agent Communication) ─────────────────────────────────────
# Get your API key at: https://app.band.ai
# Leave empty to run in mock mode (messages stored locally, printed to console)
BAND_API_KEY=your_band_api_key_here

# ── Band Agent IDs (optional — only if using real Band rooms) ────────────────
# Create each agent at https://app.band.ai/agents → Remote Agent type
BAND_ORCHESTRATOR_AGENT_ID=your_orchestrator_agent_id_here
MOMENTUM_AGENT_ID=your_momentum_agent_id_here
MEAN_REVERSION_AGENT_ID=your_mean_reversion_agent_id_here
SENTIMENT_AGENT_ID=your_sentiment_agent_id_here
STRESS_TEST_AGENT_ID=your_stress_test_agent_id_here
COMPLIANCE_AGENT_ID=your_compliance_agent_id_here
PORTFOLIO_ARBITER_ID=your_portfolio_arbiter_id_here

# ── ChromaDB Persistence ────────────────────────────────────────────────────
# Path for ChromaDB vector store (default: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db

# ── Market & News Scraping Modes ────────────────────────────────────────────
# Set to 'live' to run active financial API queries and news scrapes,
# or 'mock' to run simulation data.
MARKET_DATA_MODE=live
NEWS_SCRAPER_MODE=live

# ── Server Settings ─────────────────────────────────────────────────────────
# Binds the application to host and port.
# Railway automatically populates the PORT variable.
HOST=0.0.0.0
PORT=8000
