# ── AlgoDesk Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your keys.

# ── Groq API (Free — llama-3.3-70b-versatile) ───────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Band Platform (Agent Communication) ─────────────────────────────────────
# Get your API key at: https://app.band.ai
# Leave empty to run in mock mode (messages stored locally, printed to console)
BAND_API_KEY=

# ── Band Agent IDs (optional — only if using real Band rooms) ────────────────
# Create each agent at https://app.band.ai/agents → Remote Agent type
STRESS_TEST_AGENT_ID=
COMPLIANCE_AGENT_ID=
PORTFOLIO_ARBITER_ID=

# ── ChromaDB Persistence ────────────────────────────────────────────────────
# Path for ChromaDB vector store (default: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db

# ── Server ──────────────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
